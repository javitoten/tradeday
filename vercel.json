{
  "rewrites": [
    {
      "source": "/qv3f/static/:path(.*)",
      "destination": "https://eu-assets.i.posthog.com/static/:path"
    },
    {
      "source": "/qv3f/array/:path(.*)",
      "destination": "https://eu-assets.i.posthog.com/array/:path"
    },
    {
      "source": "/qv3f/:path(.*)",
      "destination": "https://eu.i.posthog.com/:path"
    }
  ]
}
